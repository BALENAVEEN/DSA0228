import cv2
import numpy as np

# Read image
img = cv2.imread("image5.jpg")

# Kernel
kernel = np.ones((5,5), np.uint8)

# Erode image
eroded = cv2.erode(img, kernel, iterations=1)

# Show result
cv2.imshow("Original Image", img)
cv2.imshow("Eroded Image", eroded)

cv2.waitKey(0)
cv2.destroyAllWindows()
