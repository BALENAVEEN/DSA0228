  import cv2

# Read the image
img = cv2.imread("image.jpg", 0)   # 0 = grayscale

if img is None:
    print("Image not found")
    exit()

# Apply Canny edge detection
edges = cv2.Canny(img, 100, 200)

# Display images
cv2.imshow("Original Image", img)
cv2.imshow("Canny Edge Detection", edges)

cv2.waitKey(0)
cv2.destroyAllWindows()
